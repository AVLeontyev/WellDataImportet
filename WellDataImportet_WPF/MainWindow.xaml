<Window x:Class="WellDataImportet_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Импорт данных по скважинам" Height="350" Width="525">
    <Grid>
        <Button Name="btnSelectFile" Content="Выбрать CSV файл" Width="150" Height="30" Click="btnSelectFile_Click" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        <TextBox Name="txtOutput" Margin="10,70,10,10" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" IsReadOnly="True"/>
    </Grid>
</Window>
